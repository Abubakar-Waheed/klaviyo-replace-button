{
  "manifest_version": 3,
  "name": "Klaviyo Replace Button Restorer",
  "description": "Restores Klaviyo's hidden image Replace button in the email template editor.",
  "version": "0.1.1",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.klaviyo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
